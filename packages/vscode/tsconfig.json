{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@nexuscode/core": ["../core/src/index.ts"]
    },
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "webview-ui",
    "src/services/autocomplete/**/*.test.ts",
    "src/services/autocomplete/continuedev/core/test",
    "src/services/autocomplete/continuedev/**/test/**",
    "src/services/autocomplete/**/testUtils.ts"
  ]
}
