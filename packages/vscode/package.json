{
  "name": "nexuscode",
  "displayName": "NexusCode",
  "description": "AI coding agent: agent/plan/debug/ask modes, AST + optional vector indexing, MCP, skills, rules, parallel tools, NexusCode Server. Repository: https://github.com/we11as22/NexusCode",
  "version": "0.1.0",
  "private": true,
  "publisher": "nexuscode",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["AI", "Chat", "Programming Languages"],
  "keywords": ["ai", "coding", "agent", "claude", "gpt", "nexus"],
  "repository": {
    "type": "git",
    "url": "https://github.com/we11as22/NexusCode"
  },
  "homepage": "https://github.com/we11as22/NexusCode#readme",
  "bugs": {
    "url": "https://github.com/we11as22/NexusCode/issues"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "pnpm build:ext && pnpm build:webview",
    "build:ext": "node esbuild.mjs",
    "build:webview": "pnpm --filter @nexuscode/webview-ui build",
    "package": "node scripts/svg-to-png.cjs && node scripts/package-vsix.cjs",
    "dev": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nexuscode-activitybar",
          "title": "NexusCode",
          "icon": "assets/icon.png"
        }
      ]
    },
    "views": {
      "nexuscode-activitybar": [
        {
          "type": "webview",
          "id": "nexuscode.sidebar",
          "name": "NexusCode",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "nexuscode.openPanel",
        "title": "Open NexusCode Panel",
        "category": "NexusCode",
        "icon": "$(robot)"
      },
      {
        "command": "nexuscode.sidebar.focus",
        "title": "Focus NexusCode Sidebar",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.chatClicked",
        "title": "Chat",
        "category": "NexusCode",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "nexuscode.sessionsClicked",
        "title": "Sessions",
        "category": "NexusCode",
        "icon": "$(history)"
      },
      {
        "command": "nexuscode.settingsClicked",
        "title": "Settings",
        "category": "NexusCode",
        "icon": "$(settings-gear)"
      },
      {
        "command": "nexuscode.newTask",
        "title": "New Task",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.addToChat",
        "title": "Add to NexusCode Chat",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.explainSelection",
        "title": "Explain Selection",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.improveSelection",
        "title": "Improve Selection",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.fixSelection",
        "title": "Fix (Diagnostics)",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.compact",
        "title": "Compact Conversation History",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.clearChat",
        "title": "Clear Chat",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.reindex",
        "title": "Sync Codebase Index (Incremental)",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.clearIndex",
        "title": "Delete Codebase Index (Workspace)",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.fullRebuildIndex",
        "title": "Rebuild Codebase Index from Scratch",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.deleteIndexHere",
        "title": "NexusCode: Delete Index for This Path…",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.openTerminal",
        "title": "Open NexusCode Terminal",
        "category": "NexusCode",
        "icon": "$(terminal)"
      },
      {
        "command": "nexuscode.autocomplete.generateSuggestions",
        "title": "NexusCode: Generate Inline Completion",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.autocomplete.cancelSuggestions",
        "title": "NexusCode: Cancel Inline Suggestion",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.autocomplete.reload",
        "title": "NexusCode: Reload Autocomplete",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.autocomplete.disable",
        "title": "NexusCode: Disable Inline Autocomplete",
        "category": "NexusCode"
      },
      {
        "command": "nexuscode.autocomplete.showIncompatibilityExtensionPopup",
        "title": "NexusCode: Copilot / Autocomplete Conflict",
        "category": "NexusCode"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "nexuscode.deleteIndexHere",
          "when": "explorerResourceIsFolder || resourceScheme == file",
          "group": "nexuscode@30"
        }
      ],
      "editor/context": [
        {
          "command": "nexuscode.addToChat",
          "group": "nexuscode",
          "when": "editorHasSelection"
        },
        {
          "command": "nexuscode.explainSelection",
          "group": "nexuscode",
          "when": "editorHasSelection"
        },
        {
          "command": "nexuscode.improveSelection",
          "group": "nexuscode",
          "when": "editorHasSelection"
        },
        {
          "command": "nexuscode.fixSelection",
          "group": "nexuscode",
          "when": "editorTextFocus"
        }
      ]
    },
    "keybindings": [
      {
        "command": "nexuscode.openPanel",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n"
      },
      {
        "command": "nexuscode.newTask",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "nexuscode.autocomplete.cancelSuggestions",
        "key": "escape",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && nexuscode.autocomplete.hasSuggestions"
      },
      {
        "command": "nexuscode.autocomplete.generateSuggestions",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && nexuscode.autocomplete.enableSmartInlineTaskKeybinding && !github.copilot.completions.enabled"
      },
      {
        "command": "nexuscode.autocomplete.showIncompatibilityExtensionPopup",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && nexuscode.autocomplete.enableSmartInlineTaskKeybinding && github.copilot.completions.enabled"
      }
    ],
    "configuration": {
      "title": "NexusCode",
      "properties": {
        "nexuscode.provider": {
          "type": "string",
          "default": "anthropic",
          "description": "Default LLM provider (overrides .nexus/nexus.yaml)"
        },
        "nexuscode.model": {
          "type": "string",
          "default": "claude-sonnet-4-5",
          "description": "Default model ID (overrides .nexus/nexus.yaml)"
        },
        "nexuscode.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the provider (overrides env and YAML; leave empty to use env)"
        },
        "nexuscode.serverUrl": {
          "type": "string",
          "default": "",
          "description": "NexusCode server URL (e.g. http://127.0.0.1:4097). When set, the extension uses the server for sessions and agent runs instead of running in-process."
        },
        "nexuscode.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Custom API base URL (e.g. for OpenAI-compatible or local LLM)"
        },
        "nexuscode.temperature": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 2,
          "description": "Model temperature (0-2). Lower is more deterministic."
        },
        "nexuscode.reasoningEffort": {
          "type": "string",
          "default": "",
          "description": "Reasoning effort hint for reasoning-capable models (e.g. none|minimal|low|medium|high|max). Leave empty for auto."
        },
        "nexuscode.contextWindow": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional context window override in tokens. Set 0 to use model/provider default."
        },
        "nexuscode.enableIndexing": {
          "type": "boolean",
          "default": true,
          "description": "Enable codebase indexing for semantic search"
        },
        "nexuscode.enableVectorIndex": {
          "type": "boolean",
          "default": false,
          "description": "Enable semantic vector indexing (requires embeddings + vector DB)"
        },
        "nexuscode.embeddingBatchSize": {
          "type": "number",
          "default": 60,
          "minimum": 1,
          "description": "Embedding batch size during vector indexing"
        },
        "nexuscode.embeddingConcurrency": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "Parallel embedding requests during vector indexing"
        },
        "nexuscode.enableVectorDb": {
          "type": "boolean",
          "default": false,
          "description": "Enable vector DB integration for semantic search"
        },
        "nexuscode.vectorDbUrl": {
          "type": "string",
          "default": "http://127.0.0.1:6333",
          "description": "Vector DB URL (Qdrant-compatible API endpoint)"
        },
        "nexuscode.vectorDbAutoStart": {
          "type": "boolean",
          "default": true,
          "description": "Try to auto-start local Qdrant (binary or docker) when unavailable"
        },
        "nexuscode.embeddingsProvider": {
          "type": "string",
          "default": "",
          "description": "Embeddings provider (openai, openai-compatible, ollama, local)"
        },
        "nexuscode.embeddingsModel": {
          "type": "string",
          "default": "",
          "description": "Embeddings model ID"
        },
        "nexuscode.embeddingsApiKey": {
          "type": "string",
          "default": "",
          "description": "Embeddings API key (optional)"
        },
        "nexuscode.embeddingsBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Embeddings provider base URL (for openai-compatible/ollama)"
        },
        "nexuscode.embeddingsDimensions": {
          "type": "number",
          "default": 0,
          "description": "Embeddings dimensions override (0 = provider default)"
        },
        "nexuscode.toolClassifyThreshold": {
          "type": "number",
          "default": 20,
          "description": "MCP server filtering threshold. When server count exceeds this, only selected servers are used. Higher = less filtering."
        },
        "nexuscode.skillClassifyThreshold": {
          "type": "number",
          "default": 20,
          "description": "Skill filtering threshold. Higher = less filtering."
        },
        "nexuscode.enableCheckpoints": {
          "type": "boolean",
          "default": true,
          "description": "Enable workspace checkpoints before writes (requires git)"
        },
        "nexuscode.autoApproveRead": {
          "type": "boolean",
          "default": true,
          "description": "Auto-approve file read operations (no dialog)"
        },
        "nexuscode.autoApproveWrite": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve file write operations (no diff dialog)"
        },
        "nexuscode.autoApproveCommand": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve terminal command execution"
        },
        "nexuscode.autoApproveMcp": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve MCP tool calls"
        },
        "nexuscode.autoApproveBrowser": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve browser/web actions"
        },
        "nexuscode.runCommandsInTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Run approved commands in the integrated terminal (Cline-style). When enabled, a 'NexusCode' terminal is created or reused and shown; command output is captured for the agent. When disabled, commands run in the background without opening the terminal."
        },
        "nexuscode.autocomplete.enableAutoTrigger": {
          "type": "boolean",
          "default": true,
          "description": "Show inline (ghost) code completions in the editor (Tab to accept). When off, inline autocomplete is fully disabled."
        },
        "nexuscode.autocomplete.useSeparateModel": {
          "type": "boolean",
          "default": false,
          "description": "Use the autocomplete model fields below instead of the agent model from .nexus/nexus.yaml"
        },
        "nexuscode.autocomplete.provider": {
          "type": "string",
          "default": "",
          "description": "Provider for inline autocomplete when useSeparateModel is enabled (e.g. anthropic, openai, openai-compatible)"
        },
        "nexuscode.autocomplete.model": {
          "type": "string",
          "default": "",
          "description": "Model id for inline autocomplete when useSeparateModel is enabled"
        },
        "nexuscode.autocomplete.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for autocomplete-only model (optional if env / agent key applies)"
        },
        "nexuscode.autocomplete.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for openai-compatible / local autocomplete model"
        },
        "nexuscode.autocomplete.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature for inline autocomplete requests"
        },
        "nexuscode.autocomplete.reasoningEffort": {
          "type": "string",
          "default": "",
          "description": "Optional reasoning effort for capable models (empty = default)"
        },
        "nexuscode.autocomplete.contextWindow": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional context window override for autocomplete (0 = omit)"
        },
        "nexuscode.autocomplete.enableSmartInlineTaskKeybinding": {
          "type": "boolean",
          "default": false,
          "description": "Bind Ctrl+L / Cmd+L to manually trigger inline completion (may conflict with Copilot)"
        },
        "nexuscode.autocomplete.enableChatAutocomplete": {
          "type": "boolean",
          "default": false,
          "description": "Reserved for future chat input suggestions"
        },
        "nexuscode.autocomplete.snoozeUntil": {
          "type": "number",
          "description": "Internal: timestamp until which autocomplete is snoozed (ms since epoch)"
        }
      }
    }
  },
  "dependencies": {
    "@nexuscode/core": "workspace:*",
    "diff": "^7.0.0",
    "execa": "^9.5.0",
    "fastest-levenshtein": "^1.0.16",
    "ignore": "^7.0.3",
    "js-tiktoken": "^1.0.18",
    "lru-cache": "^11.0.2",
    "openai": "^4.85.4",
    "quick-lru": "^7.0.0",
    "uri-js": "^4.4.1",
    "web-tree-sitter": "^0.25.6",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "sharp": "^0.33.5",
    "typescript": "^5.5.0",
    "esbuild": "^0.24.0"
  }
}
