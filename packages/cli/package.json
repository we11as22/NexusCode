{
  "name": "@nexuscode/cli",
  "version": "0.1.0",
  "private": false,
  "description": "NexusCode CLI — AI coding agent for the terminal",
  "bin": {
    "nexus": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --minify --target node18 --outDir dist",
    "dev": "tsup src/index.ts --format esm --target node18 --watch --outDir dist",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "dependencies": {
    "@nexuscode/core": "workspace:*",
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "@types/react": "^18.3.0",
    "yargs": "^17.7.0",
    "chalk": "^5.3.0",
    "ink-spinner": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsup": "^8.3.0"
  }
}
