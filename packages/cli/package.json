{
  "name": "@nexuscode/cli",
  "version": "0.1.0",
  "private": false,
  "description": "NexusCode CLI — AI coding agent for the terminal",
  "bin": {
    "nexus": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup && cp nexus dist/nexus && chmod +x dist/nexus",
    "dev": "tsup src/index.ts --format esm --target node18 --watch --outDir dist",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "dependencies": {
    "@nexuscode/core": "workspace:*",
    "@opentui/core": "^0.1.85",
    "@opentui/react": "^0.1.85",
    "@types/react": "^19.0.0",
    "chalk": "^5.3.0",
    "execa": "^9.5.0",
    "opentui-spinner": "^0.0.6",
    "react": "^19.0.0",
    "string-width": "^7.2.0",
    "yargs": "^17.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/yargs": "^17.0.33",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0"
  }
}
